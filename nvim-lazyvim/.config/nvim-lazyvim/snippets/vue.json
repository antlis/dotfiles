  "Pinia Store Setup": {
    "prefix": "vpinia",
    "body": [
      "export const use${1:Name}Store = defineStore('${2:id}', () => {",
      "  const ${3:state} = ref(${4:null})",
      "",
      "  const ${5:getter} = computed(() => ${3:state}.value)",
      "",
      "  function ${6:action}() {",
      "    $0",
      "  }",
      "",
      "  return { ${3:state}, ${5:getter}, ${6:action} }",
      "})"
    ],
    "description": "Pinia store with setup syntax"
  },
  "Pinia storeToRefs": {
    "prefix": "vpinia-refs",
    "body": "const { ${1:state} } = storeToRefs(use${2:Name}Store())",
    "description": "Pinia storeToRefs destructure"
