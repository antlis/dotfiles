{
  "Vue SFC Template": {
    "prefix": "vbase",
    "body": [
      "<script setup lang=\"ts\">",
      "$0",
      "</script>",
      "",
      "<template>",
      "  <div>",
      "    ",
      "  </div>",
      "</template>",
      "",
      "<style scoped>",
      "</style>"
    ],
    "description": "Vue 3 SFC with script setup, template, and scoped style"
  },
  "Vue SFC Minimal": {
    "prefix": "vbase-min",
    "body": [
      "<script setup lang=\"ts\">",
      "$0",
      "</script>",
      "",
      "<template>",
      "  <div>",
      "    ",
      "  </div>",
      "</template>"
    ],
    "description": "Vue 3 SFC minimal (no style block)"
  },

  "defineProps": {
    "prefix": "vprops",
    "body": [
      "const props = defineProps<{",
      "  ${1:name}: ${2:string}",
      "}>()"
    ],
    "description": "defineProps with TypeScript"
  },
  "defineProps with defaults": {
    "prefix": "vprops-default",
    "body": [
      "const props = withDefaults(defineProps<{",
      "  ${1:name}?: ${2:string}",
      "}>(), {",
      "  ${1:name}: ${3:undefined},",
      "})"
    ],
    "description": "defineProps with withDefaults"
  },
  "defineEmits": {
    "prefix": "vemits",
    "body": [
      "const emit = defineEmits<{",
      "  ${1:eventName}: [${2:payload}: ${3:string}]",
      "}>()"
    ],
    "description": "defineEmits with TypeScript"
  },
  "defineModel": {
    "prefix": "vmodel",
    "body": [
      "const ${1:modelValue} = defineModel<${2:string}>('${1:modelValue}')"
    ],
    "description": "defineModel"
  },
  "defineExpose": {
    "prefix": "vexpose",
    "body": [
      "defineExpose({",
      "  $0",
      "})"
    ],
    "description": "defineExpose"
  },
  "defineSlots": {
    "prefix": "vslots",
    "body": [
      "const slots = defineSlots<{",
      "  ${1:default}(props: { ${2:item}: ${3:any} }): any",
      "}>()"
    ],
    "description": "defineSlots with TypeScript"
  },

  "ref": {
    "prefix": "vref",
    "body": "const ${1:name} = ref<${2:string}>(${3:''})$0",
    "description": "Vue ref"
  },
  "reactive": {
    "prefix": "vreactive",
    "body": [
      "const ${1:state} = reactive({",
      "  ${2:key}: ${3:value},",
      "})"
    ],
    "description": "Vue reactive"
  },
  "computed": {
    "prefix": "vcomputed",
    "body": [
      "const ${1:name} = computed(() => {",
      "  return $0",
      "})"
    ],
    "description": "Vue computed"
  },
  "computed get/set": {
    "prefix": "vcomputed-gs",
    "body": [
      "const ${1:name} = computed({",
      "  get() {",
      "    return ${2}",
      "  },",
      "  set(${3:val}) {",
      "    ${0}",
      "  },",
      "})"
    ],
    "description": "Vue computed with getter and setter"
  },
  "watch": {
    "prefix": "vwatch",
    "body": [
      "watch(${1:source}, (${2:newVal}, ${3:oldVal}) => {",
